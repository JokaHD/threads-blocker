{
  "manifest_version": 3,
  "name": "Thread Blocker",
  "version": "1.0.0",
  "description": "在 Threads 留言區快速批量封鎖帳號",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "*://www.threads.net/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://www.threads.net/*"],
      "js": ["dist/content.js"],
      "css": ["dist/content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
