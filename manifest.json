{
  "manifest_version": 3,
  "name": "Threads Blocker",
  "version": "1.0.0",
  "description": "在 Threads 留言區快速批量封鎖帳號",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "*://www.threads.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://www.threads.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
