{
  "name": "threads-blocker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Chrome Extension to batch-block accounts on Threads",
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\""
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/content/content.js",
      "!src/content/debug.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 65,
        "functions": 75,
        "lines": 75
      }
    },
    "projects": [
      {
        "displayName": "node",
        "testEnvironment": "node",
        "transform": {},
        "setupFiles": [
          "./tests/jest-setup.js"
        ],
        "testMatch": [
          "**/tests/unit/**/*.test.js"
        ],
        "testPathIgnorePatterns": [
          "dom-observer",
          "token-provider",
          "id-resolver",
          "site-adapter",
          "icons",
          "toolbar",
          "panel",
          "inline-controls",
          "shadow-host",
          "sidebar"
        ]
      },
      {
        "displayName": "jsdom",
        "testEnvironment": "jsdom",
        "testEnvironmentOptions": {
          "url": "https://www.threads.com/@test"
        },
        "transform": {},
        "setupFiles": [
          "./tests/jest-setup.js"
        ],
        "testMatch": [
          "**/tests/unit/dom-observer.test.js",
          "**/tests/unit/token-provider.test.js",
          "**/tests/unit/id-resolver.test.js",
          "**/tests/unit/site-adapter.test.js",
          "**/tests/unit/icons.test.js",
          "**/tests/unit/toolbar.test.js",
          "**/tests/unit/panel.test.js",
          "**/tests/unit/inline-controls.test.js",
          "**/tests/unit/shadow-host.test.js",
          "**/tests/unit/sidebar.test.js"
        ]
      }
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@playwright/test": "^1.59.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.3"
  }
}
